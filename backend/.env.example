# ===== AI-Powered Talent Scout Agent - Environment Configuration =====

# LLM Provider: "gemini" (default) or "groq"
# If set to "gemini", the system tries Gemini first and falls back to Groq on failure.
# If set to "groq", only Groq is used.
LLM_PROVIDER=gemini

# Google Gemini API Key (free tier: 15 RPM, 1M tokens/day)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (free tier: llama-3.1-8b-instant)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Embedding Provider: "local" (default, uses @xenova/transformers) or "openai"
EMBEDDING_PROVIDER=local

# OpenAI API Key (only required if EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Server Configuration
PORT=3001
NODE_ENV=development
